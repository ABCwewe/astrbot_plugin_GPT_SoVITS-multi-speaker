{
    "enabled": {
        "description": "总开关",
        "type": "bool",
        "hint": "GPT-SoVITS 插件总开关，请在部署好 GPT-SoVITS 后再打开此开关",
        "default": true
    },
    "default_speaker": {
        "description": "默认说话人名称",
        "type": "string",
        "hint": "在不指定说话人时使用的默认说话人名称",
        "default": "default"
    },
    "speakers": {
        "description": "说话人配置列表",
        "type": "template_list",
        "hint": "每个说话人有独立的模型、服务器和情绪配置",
        "templates": {
            "speaker": {
                "name": "说话人配置",
                "items": {
                    "speaker_name": {
                        "description": "说话人名称",
                        "type": "string",
                        "hint": "说话人的唯一标识名称，用于指令中指定",
                        "default": "default"
                    },
                    "alias": {
                        "description": "说话人别名",
                        "type": "string",
                        "hint": "指令中可使用的别名，多个用逗号分隔，如：小明,xm",
                        "default": ""
                    },
                    "gpt_path": {
                        "description": "GPT 模型文件路径",
                        "type": "string",
                        "hint": "即'.ckpt'后缀的文件。请使用 '/' 分隔路径，支持绝对路径和相对路径。不填则默认用 GPT-SoVITS 内置 GPT 模型",
                        "default": ""
                    },
                    "sovits_path": {
                        "description": "SoVITS 模型文件路径",
                        "type": "string",
                        "hint": "即'.pth'后缀的文件。请使用 '/' 分隔路径，支持绝对路径和相对路径。不填则默认用 GPT-SoVITS 内置 SoVITS 模型",
                        "default": ""
                    },
                    "base_url": {
                        "description": "GPT-SoVITS API 服务器地址",
                        "type": "string",
                        "hint": "此说话人使用的 GPT-SoVITS API 地址",
                        "default": "http://127.0.0.1:9880"
                    },
                    "timeout": {
                        "description": "API 请求超时时间",
                        "type": "int",
                        "hint": "单位为秒",
                        "slider": {
                            "min": 30,
                            "max": 180,
                            "step": 1
                        },
                        "default": 60
                    },
                    "text_lang": {
                        "description": "默认合成语言",
                        "type": "string",
                        "hint": "合成语音时默认使用的语言",
                        "options": [
                            "zh",
                            "en",
                            "ja",
                            "ko",
                            "zh_ja_auto"
                        ],
                        "labels": [
                            "中文",
                            "英语",
                            "日语",
                            "韩语",
                            "中日自动"
                        ],
                        "default": "zh"
                    },
                    "emotions": {
                        "description": "情绪配置 (JSON)",
                        "type": "string",
                        "hint": "JSON 格式的情绪配置列表，每个情绪包含参考音频、文本、语言、语速、间隔等参数",
                        "editor_mode": true,
                        "editor_language": "json",
                        "editor_theme": "vs-dark",
                        "default": "[\n  {\n    \"name\": \"默认\",\n    \"keywords\": [],\n    \"ref_audio_path\": \"\",\n    \"prompt_text\": \"\",\n    \"prompt_lang\": \"zh\",\n    \"speed_factor\": 1.0,\n    \"fragment_interval\": 0.7\n  }\n]"
                    }
                }
            }
        }
    },
    "tts_params": {
        "description": "TTS 全局参数",
        "type": "object",
        "hint": "GPT-SoVITS API 的全局合成参数",
        "items": {
            "media_type": {
                "description": "输出音频格式",
                "type": "string",
                "hint": "建议 wav，兼容性好",
                "options": [
                    "wav",
                    "mp3",
                    "ogg"
                ],
                "default": "wav"
            },
            "text_split_method": {
                "description": "文本切分方式",
                "type": "string",
                "hint": "影响长文本处理效果",
                "options": [
                    "cut0",
                    "cut1",
                    "cut2",
                    "cut3",
                    "cut4",
                    "cut5"
                ],
                "labels": [
                    "不切分",
                    "四句一切",
                    "50字一切",
                    "按中文句号切",
                    "按英文句号切",
                    "按标点符号切"
                ],
                "default": "cut3"
            },
            "batch_size": {
                "description": "推理批大小",
                "type": "int",
                "hint": "越大越快但越占显存",
                "slider": {
                    "min": 1,
                    "max": 10,
                    "step": 1
                },
                "default": 1
            },
            "batch_threshold": {
                "description": "批处理阈值",
                "type": "float",
                "hint": "控制是否拆分批次",
                "slider": {
                    "min": 0.1,
                    "max": 1.0,
                    "step": 0.01
                },
                "default": 0.75
            },
            "parallel_infer": {
                "description": "启用并行推理",
                "type": "bool",
                "hint": "开启后可提升速度，建议开启",
                "default": true
            },
            "split_bucket": {
                "description": "启用分桶推理",
                "type": "bool",
                "hint": "开启后可并行处理长文本，建议开启",
                "default": true
            }
        }
    },
    "auto": {
        "description": "自动触发配置",
        "type": "object",
        "hint": "本插件有一定概率主动将 bot 本来要发送的文本转成语音发送",
        "items": {
            "only_llm_result": {
                "description": "只处理 LLM 结果",
                "type": "bool",
                "hint": "只处理 LLM 返回的消息。建议打开",
                "default": true
            },
            "tts_prob": {
                "description": "主动转语音发送的概率",
                "type": "float",
                "hint": "",
                "slider": {
                    "min": 0,
                    "max": 1,
                    "step": 0.01
                },
                "default": 0.15
            },
            "max_msg_len": {
                "description": "文本长度限制",
                "type": "int",
                "hint": "超过此长度的文本不会被转成语音发送",
                "slider": {
                    "min": 0,
                    "max": 200,
                    "step": 1
                },
                "default": 50
            }
        }
    },
    "judge": {
        "description": "LLM 情感判断配置",
        "hint": "",
        "type": "object",
        "items": {
            "enabled_llm": {
                "description": "使用 LLM 判断情感",
                "type": "bool",
                "hint": "开启后，将使用 LLM 模型判断当前文本的情绪，从而改变语音的情绪参数。若关闭，则使用情绪条目的触发词来匹配情绪",
                "default": false
            },
            "provider_id": {
                "description": "判断情感用的 LLM 提供商",
                "type": "string",
                "default": "",
                "hint": "留空或者填写的提供商不存在时，使用当前正在使用的 LLM 提供商。tip:工作较为简单，建议用稳定便宜又快速的小模型",
                "_special": "select_provider"
            }
        }
    },
    "cache": {
        "description": "缓存配置",
        "type": "object",
        "hint": "",
        "items": {
            "enabled": {
                "description": "启用语音缓存",
                "hint": "开启后，请求参数一致时直接复用本地缓存音频，减少重复推理",
                "type": "bool",
                "default": true
            },
            "expire_hours": {
                "description": "缓存过期时间 (h)",
                "hint": "单位为小时。0 表示永不过期，大于 0 时按文件修改时间判断是否过期",
                "type": "int",
                "slider": {
                    "min": 0,
                    "max": 240,
                    "step": 1
                },
                "default": 0
            },
            "path": {
                "description": "缓存路径",
                "hint": "请使用 '/' 分隔路径，支持绝对路径和相对路径；留空时默认 data/plugins_data/astrbot_plugin_GPT_SoVITS/audio",
                "type": "string",
                "default": "data/plugins_data/astrbot_plugin_GPT_SoVITS/audio"
            }
        }
    }
}
